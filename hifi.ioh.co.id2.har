:{\"en\":\"Explore more with better speed\",\"id\":\"Explore more with better speed\"},\"COMMON.INCORRECTPASSWORD\":{\"en\":\"Password doesn’t match.\",\"id\":\"Password tidak sesuai.\"},\"COMMON.PHONENUMBER\":{\"en\":\"Mobile Number\",\"id\":\"Nomor Ponsel\"},\"APPLICATION AND MAKE SURE YOU HAVE INSTALLED OVO\":{\"en\":\"application and Make sure you have installed the OVO application\",\"id\":\"aplikasi dan Pastikan Anda sudah menginstal aplikasi OVO\"},\"FOOTER.CALL.TEXT\":{\"en\":\"(021)30001515\",\"id\":\"(021)300031515\"},\"TERMINATION.TERMINATED.PROGRESS.MESSAGE\":{\"en\":\"Your Termination is already in progress\",\"id\":\"Penghentian Anda sedang berlangsung\"},\"COMMON.PAYBILL\":{\"en\":\"Pay bill\",\"id\":\"Bayar tagihan\"},\"VISION\":{\"en\":\"VISION+\",\"id\":\"VISION+\"},\"BILLPAYMENT\":{\"en\":\"Bill Payment\",\"id\":\"Pembayaran tagihan\"},\"DB.SUBPAYMENT\":{\"en\":\"Subscription Payment\",\"id\":\"Subscription Payment\"},\"PROCEEDTOREGULARPACKS\":{\"en\":\"Proceed to regular packs\"},\"DOWNLOADFAILED\":{\"en\":\"Download Failed\",\"id\":\"Gagal Mengunduh\"},\"DASHBOARDNOTFOUND\":{\"en\":\"Oops! dashboard not found\",\"id\":\"Oops! Dasbor Tidak Ditemukan\"},\"ALTERNATIVE_REG_OTP_SMSG\":{\"en\":\"Alternate Number Registration Success\",\"id\":\"Registrasi Nomor Alternatif Berhasil\"},\"VERIFIED\":{\"en\":\"verified\",\"id\":\"verified\"},\"ADDRESSLABEL\":{\"en\":\"Address\",\"id\":\"Alamat\"},\"CUSTOMERIDEMAIL\":{\"en\":\"Customer ID / Email\",\"id\":\"ID Pelanggan / Email\"},\"LOGINPAGE.RESETPASSWORDPOPUP.DESCRIPTION\":{\"en\":\"A link will sent to your email\",\"id\":\"Link akan dikirim melalui email\"},\"COMMON.TERMSCONDITIONSTEXT\":{\"en\":\"A. Buyer is obligated to finish the Card�s purchase and payment by following the procedure that is defined by Indosat Ooredoo Hutchison.\\nBuyer agree that:\\nB. Buyer is responsible to read, understand, and agree to the whole information/description of the Card (including but not limited to the coverage of delivery service, delivery address, number selection, data package) before making a purchase.\\nC. Buyer is subject to any conditions regarding purchase, payment, and the Card delivery.\\nD. Buyer is responsible for any late payment for the Card which causes the automatic cancellation for delivering the Card.\\nE. Any charges due to the purchase of the Card including but not limited to Bank administration fee and other additional charges are the Buyer�s responsibility.\",\"id\":\"A. Pembeli wajib menyelesaikan pembelian dan pembayaran Kartu dengan mengikuti prosedur yang ditentukan oleh Indosat Ooredoo Hutchison.\\nPembeli setuju bahwa:\\nB. Pembeli bertanggung jawab untuk membaca, memahami, dan menyetujui seluruh informasi/deskripsi Kartu (termasuk namun tidak terbatas pada cakupan layanan pengiriman, alamat pengiriman, pemilihan nomor, paket data) sebelum melakukan pembelian.\\nC. Pembeli tunduk pada ketentuan apa pun terkait pembelian, pembayaran, dan pengiriman Kartu\\nD. Pembeli bertanggung jawab atas keterlambatan pembayaran Kartu yang menyebabkan pembatalan pengiriman Kartu secara otomatis.\\nE. Segala biaya akibat pembelian Kartu termasuk namun tidak terbatas pada biaya administrasi Bank dan biaya tambahan lainnya menjadi tanggung jawab Pembeli.\"},\"REGISTRATION\":{\"en\":\"Registration\"},\"CSAT_FEEDBACK_BTN_TEXT_SUBMIT\":{\"en\":\"Submit\",\"id\":\"Kirim\"},\"FAILED TO LOAD PACKAGES\":{\"en\":\"Failed to load packages\",\"id\":\"Gagal memuat paket\"},\"PROMOPAGE.TERMSNCONDITIONPOINTS.ONE\":{\"en\":\"Program period starts from 10 Oct-31 Oct 2022 (Last subscription fee payment received on 31 Oct at 00.00)\",\"id\":\"Periode program mulai dari tanggal 10 Okt-31 Okt 2022 (Pembayaran biaya berlangganan terakhir diterima pada tanggal 31 Okt pukul 00.00)\"},\"YOURPAYMENTINPROGRESS\":{\"en\":\"Your payment is in progress\",\"id\":\"Pembayaran tagihan sedang dalam proses\"},\"ONT_NETWORK_1\":{\"en\":\"Network 1\",\"id\":\"Jaringan 1\"},\"ONT_NETWORK_2\":{\"en\":\"Net